# Database
POSTGRES_USER=uptime
POSTGRES_PASSWORD=uptime_secret
POSTGRES_DB=uptime_db
DATABASE_URL=postgresql://uptime:uptime_secret@localhost:5432/uptime_db

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@uptime.io

# Telegram
TELEGRAM_BOT_TOKEN=

# URLs
FRONTEND_URL=http://localhost
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws
